// ── Usage rate ring buffer (from Clawdmeter) ──────────────────
#define RATE_RING 6
struct RateSample { uint32_t ms; float pct; };
static RateSample rateRing[RATE_RING];
static uint8_t    rateCount = 0, rateHead = 0;

void usageRateSample(float pct) {
  uint32_t now = millis();
  if (rateCount > 0) {
    uint8_t l = (rateHead + RATE_RING - 1) % RATE_RING;
    if (pct + 5.0f < rateRing[l].pct) { rateCount = 0; rateHead = 0; }
  }
  rateRing[rateHead] = { now, pct };
  rateHead = (rateHead + 1) % RATE_RING;
  if (rateCount < RATE_RING) rateCount++;
}

int usageRateGroup() {
  if (rateCount < 2) return 0;
  uint8_t o = (rateHead + RATE_RING - rateCount) % RATE_RING;
  uint8_t l = (rateHead + RATE_RING - 1) % RATE_RING;
  uint32_t dt = rateRing[l].ms - rateRing[o].ms;
  if (dt < 240000UL) return 0;
  float dp = rateRing[l].pct - rateRing[o].pct;
  if (dp < 0) dp = 0;
  float rate = dp * 60000.0f / (float)dt;
  if (rate < 0.10f) return 0;
  if (rate < 0.20f) return 1;
  if (rate < 0.33f) return 2;
  return 3;
}

