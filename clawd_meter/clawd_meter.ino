void drawBar(int16_t x, int16_t y, int16_t w, int16_t h, float pct, uint16_t fg) {
  tft.fillRoundRect(x, y, w, h, 3, C_BAR_BG);
  int16_t filled = (int16_t)(constrain(pct, 0.0f, 100.0f) / 100.0f * (w - 2));
  if (filled > 0) tft.fillRoundRect(x + 1, y + 1, filled, h - 2, 2, fg);
}

void formatReset(char* buf, int mins) {
  if (mins < 0)    { strcpy(buf, "---");                                   return; }
  if (mins < 60)   { sprintf(buf, "Resets in %dm", mins);                 return; }
  if (mins < 1440) { sprintf(buf, "Resets in %dh %dm", mins/60, mins%60); return; }
  sprintf(buf, "Resets in %dd %dh", mins/1440, (mins%1440)/60);
}

// Battery icon: represents remaining quota (100 - usedPct)
void drawBattery(int16_t x, int16_t y, float usedPct) {
  float rem = constrain(100.0f - usedPct, 0.0f, 100.0f);
  int16_t bw = 20, bh = 11;
  tft.drawRect(x, y, bw, bh, C_TEXT);
  tft.fillRect(x + bw, y + 3, 3, bh - 6, C_TEXT);
  int16_t maxFill = bw - 4;
  int16_t fill = (int16_t)(rem / 100.0f * maxFill);
  uint16_t col = (rem > 50.0f) ? C_BATTERY_GREEN : (rem > 20.0f ? C_ACCENT : C_RED);
  tft.fillRect(x + 2, y + 2, maxFill, bh - 4, C_BAR_BG);
  if (fill > 0) tft.fillRect(x + 2, y + 2, fill, bh - 4, col);
}

// One usage panel — big % left, label right, tall bar
void drawPanel(int16_t py, const char* label, float pct, int reset_min) {
  tft.fillRoundRect(PANEL_X, py, PANEL_W, PANEL_H, 6, C_PANEL);
  bool hasData = (pct > 0 || reset_min >= 0);

  // Percentage — white, size 3
  char buf[8];
  if (hasData) sprintf(buf, "%d%%", (int)pct);
  else         strcpy(buf, "---%");
  tft.setTextColor(hasData ? C_WHITE : C_DIM); tft.setTextSize(3);
  tft.setCursor(PANEL_X + PANEL_PAD, py + PANEL_PAD);
  tft.print(buf);

  // Label — white, size 2, right-aligned, vertically centred with %
  tft.setTextColor(hasData ? C_WHITE : C_DIM); tft.setTextSize(2);
  int16_t lw = (int16_t)strlen(label) * 12;
  tft.setCursor(PANEL_X + PANEL_W - lw - PANEL_PAD, py + PANEL_PAD + 4);
  tft.print(label);

  // Bar — battery green
  drawBar(PANEL_X + PANEL_PAD, py + 44, PANEL_W - PANEL_PAD * 2, 20,
          hasData ? pct : 0.0f, hasData ? C_BATTERY_GREEN : C_DIM);

  // Reset countdown — size 2, white, below bar
  char resetBuf[32];
  formatReset(resetBuf, reset_min);
  tft.setTextColor(hasData ? C_WHITE : C_DIM); tft.setTextSize(2);
  tft.setCursor(PANEL_X + PANEL_PAD, py + 70);
  tft.print(resetBuf);
}

void drawTitle() {
  tft.setTextColor(C_TEXT); tft.setTextSize(2);
  tft.setCursor(PANEL_X, 8);
  tft.print("Usage");
  // Battery icon top-right, represents remaining 5h quota
  drawBattery(W - 30, 7, usage.valid ? usage.session_pct : 0.0f);
}

void drawSpinnerRow() {
  tft.fillRect(0, 194, W, H - 194, C_BG);

  // Spinner frame + label — always animated
  char spinBuf[52];
  if (usage.valid) {
    snprintf(spinBuf, sizeof(spinBuf), "%s %s...", SPIN_FRAMES[spinIdx], MSGS[msgIdx]);
  } else if (bleConnected) {
    snprintf(spinBuf, sizeof(spinBuf), "%s Fetching...", SPIN_FRAMES[spinIdx]);
  } else {
    snprintf(spinBuf, sizeof(spinBuf), "%s Advertising...", SPIN_FRAMES[spinIdx]);
  }
  int16_t tw = (int16_t)strlen(spinBuf) * 6;
  tft.setTextColor(usage.valid ? C_ACCENT : C_DIM);
  tft.setTextSize(1);
  tft.setCursor((W - tw) / 2, 204);
  tft.print(spinBuf);

  // Status line
  if (!usage.valid && !bleConnected) {
    const char* hint = "Pair: 'Claude Controller'";
    tft.setTextColor(C_DIM); tft.setTextSize(1);
    tft.setCursor((W - (int16_t)strlen(hint) * 6) / 2, 218);
    tft.print(hint);
  } else {
    // BLE dot label bottom-right
    tft.setTextColor(bleConnected ? C_GREEN : C_DIM);
    tft.setCursor(W - 14 * 6, 220);
    tft.print(bleConnected ? "  connected" : " advertising");
  }
}

void drawScreen() {
  tft.fillScreen(C_BG);
  drawTitle();
  drawPanel(PANEL1_Y, "Current", usage.session_pct, usage.session_reset_min);
  drawPanel(PANEL2_Y, "Weekly",  usage.weekly_pct,  usage.weekly_reset_min);
}

void drawWordScreen() {
  tft.fillScreen(C_BG);
  const char* word = MSGS[msgIdx];
  uint8_t wlen = (uint8_t)strlen(word);

  // Largest size where the word fits within the screen width (no clipping)
  uint8_t sz = 2;
  for (uint8_t s = 6; s >= 2; s--) {
    if ((int16_t)wlen * 6 * s <= W) { sz = s; break; }
  }

  int16_t charH  = 8 * sz;
  // Vertical layout: label(16) + gap(6) + word + gap(8) + dots(16)
  int16_t totalH = 16 + 6 + charH + 8 + 16;
  int16_t y      = (H - totalH) / 2;

  // "claude is" label — size 2
  tft.setTextColor(C_DIM); tft.setTextSize(2);
  const char* label = "claude is";
  tft.setCursor((W - (int16_t)strlen(label) * 12) / 2, y);
  tft.print(label);

  // Big -ing word, horizontally centered
  tft.setTextColor(C_ACCENT); tft.setTextSize(sz);
  tft.setCursor((W - (int16_t)wlen * 6 * sz) / 2, y + 22);
  tft.print(word);

  // "..." below — size 2
  tft.setTextColor(C_DIM); tft.setTextSize(2);
  tft.setCursor((W - 36) / 2, y + 22 + charH + 8);
  tft.print("...");
}

// ═════════════════════════════════════════════════════════════
//  SPRITE SCREEN
// ═════════════════════════════════════════════════════════════

// Draw one animation frame full-screen (20×20 cells, 12px each = 240px).
// Only redraws cells that differ from the previous frame to minimise flicker.
static uint8_t prevFrameBuf[400];
static bool    prevFrameValid = false;

void drawSpriteFrame(int animIdx, uint8_t frame) {
  const SpriteAnim& anim = ALL_ANIMS[animIdx];
  const uint8_t* fp = anim.frames[frame];

  for (int i = 0; i < 400; i++) {
    uint8_t v = pgm_read_byte(&fp[i]);
    if (prevFrameValid && prevFrameBuf[i] == v) continue;
    uint16_t col;
    if (v == 0 || v >= anim.npal) {
      col = C_BG;
    } else {
      col = pgm_read_word(&anim.palette[v]);
    }
    int r = i / 20, c = i % 20;
    tft.fillRect(c * SPRITE_CELL, r * SPRITE_CELL, SPRITE_CELL, SPRITE_CELL, col);
  }

  for (int i = 0; i < 400; i++) prevFrameBuf[i] = pgm_read_byte(&fp[i]);
  prevFrameValid = true;
}

void enterSpriteMode() {
  displayMode    = MODE_SPRITE;
  modeLastSwitch = millis();
  prevFrameValid = false;   // force full redraw
  animFrame      = 0;
  animDeadline   = millis();
}

void enterWordMode() {
  msgIdx         = random(MSG_COUNT);
  displayMode    = MODE_WORD;
  modeLastSwitch = millis();
  prevFrameValid = false;
  drawWordScreen();
}

void enterUsageMode() {
  displayMode    = MODE_USAGE;
  modeLastSwitch = millis();
  prevFrameValid = false;
  drawScreen();
}

// ═════════════════════════════════════════════════════════════
//  BLE
// ═════════════════════════════════════════════════════════════

class BleServerCb : public NimBLEServerCallbacks {
  void onConnect(NimBLEServer*, NimBLEConnInfo&) override {
    bleConnected   = true;
    bleStateChange = true;
  }
  void onDisconnect(NimBLEServer*, NimBLEConnInfo&, int) override {
    bleConnected   = false;
    bleStateChange = true;
    NimBLEDevice::getAdvertising()->start();
  }
};

class BleRxCb : public NimBLECharacteristicCallbacks {
  void onWrite(NimBLECharacteristic* chr, NimBLEConnInfo&) override {
    std::string val = chr->getValue();
    size_t len = val.length() < 511 ? val.length() : 511;
    memcpy(bleBuf, val.c_str(), len);
    bleBuf[len] = '\0';
    bleDataReady = true;
  }
};

class BleReqCb : public NimBLECharacteristicCallbacks {
  void onSubscribe(NimBLECharacteristic*, NimBLEConnInfo&, uint16_t sub) override {
    if (sub != 0 && !usage.valid) {
      uint8_t v = 0x01;
      bleReqChar->setValue(&v, 1);
      bleReqChar->notify();
    }
  }
};

void bleInit() {
  NimBLEDevice::init(BLE_DEVICE_NAME);
  NimBLEDevice::setSecurityAuth(false, false, false);

  NimBLEServer* srv = NimBLEDevice::createServer();
  static BleServerCb srvCb;
  srv->setCallbacks(&srvCb);

  NimBLEService* svc = srv->createService(BLE_SVC_UUID);

  NimBLECharacteristic* rx = svc->createCharacteristic(
    BLE_RX_UUID, NIMBLE_PROPERTY::WRITE | NIMBLE_PROPERTY::WRITE_NR);
  static BleRxCb rxCb;
  rx->setCallbacks(&rxCb);

  bleTxChar = svc->createCharacteristic(
    BLE_TX_UUID, NIMBLE_PROPERTY::READ | NIMBLE_PROPERTY::NOTIFY);

  bleReqChar = svc->createCharacteristic(
    BLE_REQ_UUID, NIMBLE_PROPERTY::NOTIFY);
  static BleReqCb reqCb;
  bleReqChar->setCallbacks(&reqCb);

  svc->start();
  srv->start();

  NimBLEAdvertising* adv = NimBLEDevice::getAdvertising();
  adv->addServiceUUID(BLE_SVC_UUID);
  adv->setName(BLE_DEVICE_NAME);
  adv->start();
  Serial.println("BLE: advertising as 'Claude Controller'");
}

// ═════════════════════════════════════════════════════════════
//  SETUP / LOOP
// ═════════════════════════════════════════════════════════════

void setup() {
  Serial.begin(115200);

  pinMode(TFT_BLK, OUTPUT);
  digitalWrite(TFT_BLK, HIGH);

  SPI.begin(8, -1, 10, TFT_CS);
  tft.init(240, 240);
  tft.setSPISpeed(40000000);
  tft.setRotation(1);

  initColors();
  bleInit();

  msgLastMs = spinLastMs = millis();
  enterSpriteMode();
}

void loop() {
  uint32_t now = millis();

  // ── Incoming BLE message (highest priority) ──────────────
  if (bleDataReady) {
    bleDataReady = false;
    JsonDocument doc;
    if (deserializeJson(doc, bleBuf) == DeserializationError::Ok) {

      // Animation override command: {"anim": 0-12} or {"anim": -1} for auto
      if (doc.containsKey("anim")) {
        int a = doc["anim"].as<int>();
        animOverride   = (a >= 0 && a <= 12) ? a : -1;
        animFrame      = 0;
        animDeadline   = millis();
        groupRotateDue = millis() + GROUP_ROTATE_MS;
        prevFrameValid = false;
        if (animOverride < 0) {
          animGroup  = usageRateGroup();
          animSubIdx = 0;
        }
        if (displayMode != MODE_SPRITE) enterSpriteMode();
        if (bleConnected && bleTxChar) {
          bleTxChar->setValue("{\"ack\":true}");
          bleTxChar->notify();
        }
        goto done_ble;
      }

      // Mode command: {"mode":"sprite"} or {"mode":"usage"}
      if (doc.containsKey("mode")) {
        const char* m = doc["mode"] | "";
        if (strcmp(m, "sprite") == 0) enterSpriteMode();
        else if (strcmp(m, "usage") == 0) enterUsageMode();
        if (bleConnected && bleTxChar) {
          bleTxChar->setValue("{\"ack\":true}");
          bleTxChar->notify();
        }
        goto done_ble;
      }

      // Usage data payload: {"s":..., "sr":..., "w":..., "wr":..., "st":..., "h":...}
      if (doc.containsKey("s")) {
        // Time of day
        if (doc.containsKey("h")) timeHour = (int8_t)(doc["h"].as<int>());

        float newPct = doc["s"] | 0.0f;
        // Reset celebration: usage dropped from >30% down to <10%
        bool resetOccurred = (prevSessionPct > 30.0f && newPct < 10.0f);
        prevSessionPct = newPct;

        usage.session_pct       = newPct;
        usage.session_reset_min = doc["sr"] | -1;
        usage.weekly_pct        = doc["w"]  | 0.0f;
        usage.weekly_reset_min  = doc["wr"] | -1;
        strlcpy(usage.status, doc["st"] | "unknown", sizeof(usage.status));
        usage.valid = true;
        usageRateSample(usage.session_pct);

        if (resetOccurred) {
          celebrateUntil = millis() + CELEBRATE_MS;
          animFrame = 0; animDeadline = millis(); prevFrameValid = false;
          enterSpriteMode();
        } else if (displayMode == MODE_USAGE) {
          drawScreen();
        } else {
          enterWordMode();
        }
        if (bleConnected && bleTxChar) {
          bleTxChar->setValue("{\"ack\":true}");
          bleTxChar->notify();
        }
      }

    } else {
      if (bleConnected && bleTxChar) {
        bleTxChar->setValue("{\"err\":true}");
        bleTxChar->notify();
      }
    }
    done_ble:;
  }

  // ── BLE state change ──────────────────────────────────────
  if (bleStateChange) {
    bleStateChange = false;
    if      (displayMode == MODE_USAGE) drawScreen();
    else if (displayMode == MODE_WORD)  drawWordScreen();
  }

  // ── Screen-mode cycling (skip during celebration) ────────
  if (now >= celebrateUntil) {
    if (displayMode == MODE_SPRITE) {
      if (now - modeLastSwitch >= SPRITE_SHOW_MS) enterWordMode();
    } else if (displayMode == MODE_WORD) {
      if (now - modeLastSwitch >= WORD_SHOW_MS)   enterUsageMode();
    } else {
      if (now - modeLastSwitch >= USAGE_SHOW_MS)  enterSpriteMode();
    }
  }

  // ── Sprite animation tick ─────────────────────────────────
  if (displayMode == MODE_SPRITE) {
    int animIdx;
    if (now < celebrateUntil) {
      animIdx = 12;  // DJ Mix celebration
    } else if (animOverride >= 0) {
      animIdx = animOverride;
    } else {
      // Auto: resolve rate group, rotate within group every GROUP_ROTATE_MS
      int grp = usageRateGroup();
      if (grp != animGroup) {
        animGroup      = grp;
        animSubIdx     = 0;
        animFrame      = 0;
        animDeadline   = now;
        groupRotateDue = now + GROUP_ROTATE_MS;
        prevFrameValid = false;
      } else if (now >= groupRotateDue) {
        uint8_t glen = RATE_GROUP_LENS[animGroup];
        animSubIdx     = (animSubIdx + 1) % glen;
        animFrame      = 0;
        animDeadline   = now;
        groupRotateDue = now + GROUP_ROTATE_MS;
        prevFrameValid = false;
      }
      uint8_t glen = RATE_GROUP_LENS[animGroup];
      animSubIdx = animSubIdx % glen;

      // Time-of-day override for group 0 (truly idle, no usage rate)
      if (grp == 0 && timeHour >= 0) {
        if      (timeHour >= 23 || timeHour < 6)  animIdx = 5;  // sleep: night
        else if (timeHour < 10)                    animIdx = 8;  // coding: morning
        else if (timeHour >= 18)                   animIdx = 6;  // bounce: evening
        else                                       animIdx = RATE_GROUP_INDICES[0][animSubIdx % 3];
      } else {
        animIdx = RATE_GROUP_INDICES[animGroup][animSubIdx];
      }
    }
    if (now >= animDeadline) {
      drawSpriteFrame(animIdx, animFrame);
      const SpriteAnim& anim = ALL_ANIMS[animIdx];
      uint16_t hold = pgm_read_word(&anim.holds[animFrame]);
      animDeadline = now + hold;
      animFrame = (animFrame + 1) % anim.nframes;
    }
    return;  // skip usage-screen spinner while in sprite mode
  }

}
